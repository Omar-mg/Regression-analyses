      "source": [
        "# ── OLS Regression Model ────────────────────────────────────\n",
        "# Define the dependent variable (Sales) and independent variable (best_predictor, which is 'TV')\n",
        "y = df['Sales']\n",
        "X = df[best_predictor]\n",
        "\n",
        "# Add a constant to the independent variable for the intercept\n",
        "X = sm.add_constant(X)\n",
        "\n",
        "# Create and fit the OLS model\n",
        "model = sm.OLS(y, X)\n",
        "results = model.fit()\n",
        "\n",
        "print(\"✅ OLS model fitted successfully.\")\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"         MODEL SUMMARY\")\n",
        "print(\"=\" * 60)\n",
        "print(results.summary())\n",
        "\n",
        "# Extract key model statistics\n",
        "r_squared     = results.rsquared\n",
        "adj_r_squared = results.rsquared_adj\n",
        "intercept     = results.params['const']\n",
        "slope         = results.params[best_predictor]\n",
        "p_val_slope   = results.pvalues[best_predictor]\n",
        "p_val_inter   = results.pvalues['const']\n",
        "f_stat        = results.fvalue\n",
        "f_pval        = results.f_pvalue\n",
        "conf_int      = results.conf_int()\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"         MODEL PERFORMANCE SUMMARY\")\n",
        "print(\"=\" * 60)\n",
        "print(f\"  R-squared          : {r_squared:.6f}\")\n",
        "print(f\"  Adjusted R-squared : {adj_r_squared:.6f}\")\n",
        "print(f\"  F-statistic        : {f_stat:,.2f}\")\n",
        "print(f\"  Prob (F-statistic) : {f_pval:.2e}\")\n",
        "print()\n",
        "print(\"=\" * 60)\n",
